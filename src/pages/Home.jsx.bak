      {/* ─── STYLES ───────────────────────────────────── */}
      <style>{`
        .page-content { scroll-behavior:smooth }
        @keyframes mg { 0%,100%{background-position:0% 50%} 50%{background-position:100% 50%} }
        @keyframes mp { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.6;transform:scale(1.08)} }
