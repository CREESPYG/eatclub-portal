  const updateResources = [
    { label: 'Live Tagging Sheet',   icon: 'format_list_bulleted_add', desc: 'Real-time repository for all complaint tagging requirements.',     color: '#4CAF50', url: 'https://docs.google.com/spreadsheets/d/1-tp-LPML52Mo3hJzbiP3DrhB9R7K-qOr6RJRGkh2HLs/edit?pli=1&gid=129536738#gid=129536738' },
    { label: 'CC Master Data Sheet', icon: 'database',                  desc: 'Comprehensive master guide for Zomato, Swiggy, and Clear Feedback tagging logic.', color: '#2196F3', url: 'https://docs.google.com/spreadsheets/d/1EdJoqNdLO92dSeC0XkxySB24XB-JD-8Uf3VP01mpfD0/edit?gid=1396029481#gid=1396029481' },
