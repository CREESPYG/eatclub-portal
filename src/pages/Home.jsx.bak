    { title: 'Training Part-4 (Day 2)', duration: '0:25:39', url: 'https://drive.google.com/file/d/1Gbi5tvpJ5r0dH35AnsDGXFsvDo7fLTbn/view' },
  ];

  const tabs = [
    { label: 'Web WhatsApp',           url: 'https://web.whatsapp.com/',    icon: 'chat',       priority: 1 },
    { label: 'Outlet Current Status',  url: 'https://tinyurl.com/yfh6ypdp', icon: 'storefront', priority: 2 },
    { label: 'Employee Check-in',      url: 'https://tinyurl.com/33af2c4m', icon: 'how_to_reg', priority: 3 },
    { label: 'Critical Assets Sheet',  url: 'https://tinyurl.com/yxa5e8wr', icon: 'warning',    priority: 4 },
    { label: 'SaaS Dashboard',         url: 'https://saas.box8.co.in',      icon: 'dashboard',  priority: 5 },
    { label: 'Kaleyra (Calls)',        url: 'https://voice.kaleyra.com',    icon: 'call',       priority: 6 },
    { label: 'Inventory Check',        url: 'https://tinyurl.com/4j3t724b', icon: 'inventory',  priority: 7 },
  ];

  const brands = [
    { icon: '\uD83C\uDF5B', name: 'BOX8',             cuisine: 'Indian Home-Style Meals', color: '#FF5722', url: 'https://eatclub.in/box8' },
