      {/* ═══════════════════════════════════════════════
          STATS
      ═══════════════════════════════════════════════ */}
      <Section icon="monitoring" title="Platform at a Glance" badge="6 metrics">
        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(150px, 1fr))', gap: 12 }}>
          {[
            ['450+', 'Outlets', 'storefront', '#FF5722'],
            ['7',    'Cities',  'location_city', '#2196F3'],
            ['8+',   'Brands',  'restaurant', '#4CAF50'],
            ['20',   'Modules', 'grid_view', '#9C27B0'],
            ['180+', 'Templates', 'tag', '#FF8F00'],
            ['75+',  'Tags',    'label', '#00BCD4'],
          ].map(([num, label, icon, color]) => (
            <div key={label} className="m-stat">
              <div style={{
                width: 38, height: 38, borderRadius: 10,
                background: color + '16', display: 'flex',
                alignItems: 'center', justifyContent: 'center',
                margin: '0 auto 8px',
              }}>
                <span className="material-symbols-outlined" style={{ fontSize: 19, color }}>{icon}</span>
              </div>
              <div style={{
                fontSize: 28, fontWeight: 800,
                background: `linear-gradient(135deg,${color},${color}88)`,
                WebkitBackgroundClip: 'text', WebkitTextFillColor: 'transparent',
                backgroundClip: 'text', lineHeight: 1,
              }}>{num}</div>
              <div style={{ fontSize: 11, color: S.OnSV, marginTop: 5, fontWeight: 700, letterSpacing: .5, textTransform: 'uppercase' }}>{label}</div>
            </div>
          ))}
        </div>
      </Section>

      {/* ═══════════════════════════════════════════════
          USPs
      ═══════════════════════════════════════════════ */}
      <Section id="usps" icon="verified" title="Why Customers Choose EatClub" badge="6 reasons">
        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(240px, 1fr))', gap: 10 }}>
          {usps.map((u) => (
            <div key={u.label} className="m-usp" style={{ borderLeft: `4px solid ${u.color}` }}>
              <div style={{
                width: 42, height: 42, borderRadius: 10,
                background: `${u.color}14`, display: 'flex',
                alignItems: 'center', justifyContent: 'center', flexShrink: 0,
              }}>
                <span className="material-symbols-outlined" style={{ fontSize: 22, color: u.color }}>{u.icon}</span>
              </div>
              <div>
                <div style={{ fontSize: 14, fontWeight: 800, color: S.OnS }}>{u.label}</div>
                <div style={{ fontSize: 12, color: S.OnSV, marginTop: 1 }}>{u.sub}</div>
              </div>
            </div>
          ))}
        </div>
      </Section>

      {/* ═══════════════════════════════════════════════
          BRANDS
      ═══════════════════════════════════════════════ */}
      <Section id="brands" icon="restaurant_menu" title="Brands on EatClub" badge="8 brands">
        <div style={{ display: 'flex', gap: 12, overflow: 'auto', paddingBottom: 10, scrollSnapType: 'x mandatory', scrollbarWidth: 'thin' }}>
          {brands.map(b => (
            <a key={b.name} href={b.url} target="_blank" rel="noreferrer"
              className="m-brand"
              style={{ '--bc': b.color, scrollSnapAlign: 'start', borderColor: hoveredBrand === b.name ? b.color + '50' : S.Out }}
              onMouseEnter={e => { setHoveredBrand(b.name); e.currentTarget.style.borderColor = b.color + '60'; e.currentTarget.style.boxShadow = `0 14px 36px ${b.color}18` }}
              onMouseLeave={e => { setHoveredBrand(null); e.currentTarget.style.borderColor = S.Out; e.currentTarget.style.boxShadow = '' }}>
              <div style={{ fontSize: 34, filter: hoveredBrand === b.name ? 'none' : 'grayscale(.2) sepia(.08)', transition: 'filter .3s' }}>{b.icon}</div>
              <div style={{ fontSize: 12, fontWeight: 800, color: b.color, textAlign: 'center', lineHeight: 1.2 }}>{b.name}</div>
              <div style={{ fontSize: 9, color: S.OnSV, textAlign: 'center', lineHeight: 1.3, fontWeight: 500 }}>{b.cuisine}</div>
            </a>
          ))}
        </div>
      </Section>

      {/* ═══════════════════════════════════════════════
          MODULES
      ═══════════════════════════════════════════════ */}
      <Section id="modules" icon="grid_view" title="All Training Modules" badge="20 modules">
        <div ref={modScrollRef} className="m-mod-scroll" style={{ display: 'flex', gap: 16, overflowX: 'auto', overflowY: 'hidden', padding: '8px 4px 14px', scrollSnapType: 'x mandatory', scrollbarWidth: 'thin' }}>
          {modules.map((m) => (
            <div key={m.id} className="m-mod"
              style={{ '--mc': m.color, minWidth: 280, maxWidth: 290, flexShrink: 0, scrollSnapAlign: 'start' }}
              onClick={() => { if (!modDrag.current.moved) navigate(m.id); }}
              onMouseMove={e => {
                setHoveredMod(m.id);
                const rect = e.currentTarget.getBoundingClientRect();
                const x = ((e.clientX - rect.left) / rect.width * 100).toFixed(1);
                const y = ((e.clientY - rect.top) / rect.height * 100).toFixed(1);
                e.currentTarget.style.setProperty('--mx', x + '%');
                e.currentTarget.style.setProperty('--my', y + '%');
              }}
              onMouseLeave={e => setHoveredMod(null)}>
              {m.isNew && (
                <div style={{
                  position: 'absolute', top: -1, right: 14,
                  background: 'linear-gradient(135deg,var(--md-primary),#FF8F00)',
                  color: '#fff', fontSize: 8, fontWeight: 800,
                  padding: '2px 9px', borderRadius: '0 0 8px 8px',
                  letterSpacing: .7, zIndex: 3,
                  boxShadow: '0 4px 12px rgba(var(--md-primary-rgb),.3)',
                  animation: 'mp 2s ease-in-out infinite',
                }}>NEW</div>
              )}
              <div className="m-mod-inner" style={{ transition: 'transform .35s cubic-bezier(.34,1.56,.64,1)', willChange: 'transform' }}>
              <span style={{ fontSize: 32, display: 'block', marginBottom: 10 }}>{m.icon}</span>
              <div style={{ fontSize: 15, fontWeight: 800, color: S.OnS, marginBottom: 5 }}>{m.title}</div>
              <div style={{ fontSize: 13, color: S.OnSV, lineHeight: 1.65, flex: 1 }}>{m.desc}</div>
              <div style={{
                display: 'flex', alignItems: 'center', gap: 5,
                fontSize: 12, color: S.P, fontWeight: 700,
                marginTop: 10, borderTop: '1px solid var(--md-outline-var)',
                paddingTop: 10,
              }}>
                Open module <span className="material-symbols-outlined" style={{ fontSize: 14 }}>arrow_forward</span>
              </div>
              </div>
            </div>
          ))}
        </div>
      </Section>

      {/* ═══════════════════════════════════════════════
          PHONES + VIDEOS
      ═══════════════════════════════════════════════ */}
      <Section id="phones" icon="phone" title="Bridge Numbers & Training Videos" badge="11 numbers · 4 videos">
        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(300px, 1fr))', gap: 20 }}>

          {/* ── Phone Numbers ── */}
          <div>
            <div style={{ display: 'flex', alignItems: 'center', gap: 8, padding: '10px 14px', borderRadius: 12, background: 'rgba(255,152,0,.08)', border: '1px solid rgba(255,152,0,.2)', fontSize: 12, marginBottom: 16, lineHeight: 1.5, fontWeight: 700, color: '#FF9800' }}>
              <span className="material-symbols-outlined" style={{ fontSize: 18, flexShrink: 0 }}>warning</span>
              Save ALL numbers to identify callers instantly!
            </div>

            {[
              { title: 'Incoming Calls', data: phonesIn, color: '#4CAF50', icon: 'call_received' },
              { title: 'Outgoing Calls', data: phonesOut, color: '#2196F3', icon: 'call_made' },
            ].map(group => (
              <div key={group.title} style={{
                background: S.S, borderRadius: 14, border: `1px solid ${group.color}22`,
                overflow: 'hidden', marginBottom: 14,
                boxShadow: `0 2px 8px ${group.color}08`,
              }}>
                <div style={{
                  display: 'flex', alignItems: 'center', gap: 10, padding: '10px 16px',
                  background: group.color + '0c',
                  borderBottom: `1px solid ${group.color}18`,
                }}>
                  <span className="material-symbols-outlined" style={{ fontSize: 18, color: group.color }}>{group.icon}</span>
                  <span style={{ fontSize: 13, fontWeight: 800, color: group.color, letterSpacing: .5 }}>{group.title}</span>
                  <span style={{ fontSize: 11, color: group.color + 'aa', marginLeft: 'auto', fontWeight: 700 }}>
                    {group.data.length} number{group.data.length > 1 ? 's' : ''}
                  </span>
                </div>
                {group.data.map((p, idx) => (
                  <div key={p.number} style={{
                    display: 'flex', alignItems: 'center', gap: 10, padding: '10px 16px',
                    borderBottom: idx < group.data.length - 1 ? `1px solid ${group.color}10` : 'none',
                    transition: 'background .15s',
                  }}
                    onMouseEnter={e => e.currentTarget.style.background = group.color + '06'}
                    onMouseLeave={e => e.currentTarget.style.background = 'transparent'}>
                    <div style={{
                      width: 32, height: 32, borderRadius: 8,
                      background: group.color + '10',
                      display: 'flex', alignItems: 'center', justifyContent: 'center', flexShrink: 0,
                    }}>
                      <span className="material-symbols-outlined" style={{ color: group.color, fontSize: 16 }}>{p.icon}</span>
                    </div>
                    <div style={{ flex: 1, minWidth: 0 }}>
                      <div style={{ fontFamily: 'var(--font-mono)', fontWeight: 800, fontSize: 15, color: S.OnS, letterSpacing: .5 }}>{p.number}</div>
                      <div style={{ fontSize: 12, color: S.OnSV, fontWeight: 500, marginTop: 1 }}>{p.label}</div>
                    </div>
                    <button onClick={async () => { try { await navigator.clipboard.writeText(p.number); setCopiedNumber(p.number); setTimeout(() => setCopiedNumber(null), 2000); } catch {} }}
                      style={{
                        background: 'none', border: 'none', borderRadius: 8, width: 32, height: 32,
                        display: 'flex', alignItems: 'center', justifyContent: 'center',
                        cursor: 'pointer', color: group.color, opacity: .5, transition: 'all .2s', flexShrink: 0,
                      }}
                      onMouseEnter={e => { e.currentTarget.style.opacity = '1'; e.currentTarget.style.background = group.color + '14' }}
                      onMouseLeave={e => { e.currentTarget.style.opacity = '.5'; e.currentTarget.style.background = 'none' }}>
                      <span className="material-symbols-outlined" style={{ fontSize: 14 }}>content_copy</span>
                    </button>
                  </div>
                ))}
              </div>
            ))}

            {/* Dashboard links */}
            <div style={{ display: 'flex', flexWrap: 'wrap', gap: 8 }}>
              {[
                { href: 'https://cloud.yellow.ai/bot/x1668420084925/inbox/monitor', icon: 'forum', label: 'Yellow.ai Inbox' },
                { href: 'https://dashboard.tawk.to/login#/dashboard', icon: 'mail', label: 'tawk.to Dashboard' },
              ].map(l => (
                <a key={l.label} href={l.href} target="_blank" rel="noopener noreferrer" style={{
                  display: 'inline-flex', alignItems: 'center', gap: 8,
                  padding: '8px 16px', borderRadius: 100,
                  background: S.S2, border: '1px solid var(--md-outline)',
                  color: S.OnS, textDecoration: 'none', fontSize: 11, fontWeight: 700,
                  transition: 'all .2s',
                }}
                  onMouseEnter={e => { e.currentTarget.style.borderColor = S.P; e.currentTarget.style.background = `rgba(${S.Prgb},.1)` }}>
                  <span className="material-symbols-outlined" style={{ fontSize: 15, color: S.P }}>{l.icon}</span>
                  {l.label}
                </a>
              ))}
            </div>
          </div>

          {/* ── Training Videos (YouTube-style feed) ── */}
          <div>
            <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(180px, 1fr))', gap: 10 }}>
              {videos.map((v) => (
                <div key={v.title} onClick={() => setActiveVideo(v)}
                  style={{
                    cursor: 'pointer', borderRadius: 14, overflow: 'hidden',
                    border: '1px solid var(--md-outline)',
                    background: S.SV, transition: 'all .3s cubic-bezier(.34,1.56,.64,1)',
                  }}
                  onMouseEnter={e => { e.currentTarget.style.transform = 'translateY(-4px) scale(1.02)'; e.currentTarget.style.boxShadow = '0 12px 32px rgba(0,0,0,.2)'; e.currentTarget.style.borderColor = S.P }}
                  onMouseLeave={e => { e.currentTarget.style.transform = ''; e.currentTarget.style.boxShadow = ''; e.currentTarget.style.borderColor = 'var(--md-outline)' }}>
                  <div style={{
                    position: 'relative', width: '100%', paddingTop: '56%',
                    background: `linear-gradient(135deg, rgba(${S.Prgb},.15), rgba(${S.Prgb},.05))`,
                    display: 'flex', alignItems: 'center', justifyContent: 'center',
                  }}>
                    <div style={{
                      position: 'absolute', inset: 0, display: 'flex',
                      alignItems: 'center', justifyContent: 'center',
                    }}>
                      <div style={{
                        width: 50, height: 50, borderRadius: '50%',
                        background: `linear-gradient(135deg, ${S.P}, #FF8F00)`,
                        display: 'flex', alignItems: 'center', justifyContent: 'center',
                        boxShadow: '0 4px 16px rgba(0,0,0,.3)',
                        transition: 'transform .3s ease',
                      }} className="m-vid-play">
                        <span className="material-symbols-outlined" style={{ color: '#fff', fontSize: 24 }}>play_arrow</span>
                      </div>
                    </div>
                    <div style={{
                      position: 'absolute', bottom: 8, right: 8,
                      background: 'rgba(0,0,0,.75)', color: '#fff',
                      fontSize: 10, fontWeight: 700, padding: '2px 8px',
                      borderRadius: 6, letterSpacing: .3,
                    }}>{v.duration}</div>
                  </div>
                  <div style={{ padding: '12px 14px 14px' }}>
                    <div style={{ fontSize: 14, fontWeight: 700, color: S.OnS, lineHeight: 1.3 }}>{v.title}</div>
                    <div style={{ fontSize: 11, color: S.OnSV, marginTop: 3, display: 'flex', alignItems: 'center', gap: 4 }}>
                      <span className="material-symbols-outlined" style={{ fontSize: 13 }}>schedule</span>
                      {v.duration}
                    </div>
                  </div>
                </div>
              ))}
            </div>

            <div style={{ marginTop: 14, padding: 14, borderRadius: 14, background: S.S2, border: '1px solid var(--md-outline)', borderLeft: '4px solid var(--md-primary)' }}>
              <div style={{ display: 'flex', gap: 10, alignItems: 'flex-start' }}>
                <span className="material-symbols-outlined" style={{ fontSize: 18, color: S.P, flexShrink: 0, marginTop: 1 }}>bolt</span>
                <div>
                  <div style={{ fontSize: 12, fontWeight: 800, marginBottom: 5, color: S.P }}>Today's Quick Reminder</div>
                  <div style={{ fontSize: 11, color: S.OnSV, lineHeight: 1.8 }}>
                    {'\uD83D\uDD34'} NEVER increase a rating above what the customer gave.<br />
                    {'\uD83D\uDFE0'} Always verify N-1 before giving a refund.<br />
                    {'\uD83D\uDFE2'} Stone/Bone = Max \u20B9500 OR Specific Product Amount.
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* ── Browser Tabs ── */}
        <div style={{ marginTop: 24, paddingTop: 20, borderTop: '1px solid var(--md-outline-var)' }}>
          <div style={{ display: 'flex', alignItems: 'center', gap: 10, marginBottom: 14, padding: '0 2px' }}>
            <span className="material-symbols-outlined" style={{ fontSize: 18, color: S.P }}>tab</span>
            <span style={{ fontSize: 14, fontWeight: 800, color: S.OnS }}>Always-Open Browser Tabs</span>
            <span style={{ fontSize: 10, color: S.OnSV, marginLeft: 'auto', fontWeight: 600 }}>{tabs.length} links</span>
          </div>
          <div style={{ display: 'flex', flexWrap: 'wrap', gap: 10 }}>
            {tabs.map((t) => (
              <a key={t.label} href={t.url} target="_blank" rel="noopener noreferrer" style={{
                display: 'inline-flex', alignItems: 'center', gap: 12,
                padding: '12px 26px', borderRadius: 100,
                background: S.SV, border: '1.5px solid var(--md-outline)',
                color: S.OnS, textDecoration: 'none',
                fontSize: 15, fontWeight: 700,
                transition: 'all .25s cubic-bezier(.34,1.56,.64,1)',
              }}
                onMouseEnter={e => { e.currentTarget.style.borderColor = S.P; e.currentTarget.style.background = `rgba(${S.Prgb},.1)`; e.currentTarget.style.transform = 'translateY(-2px) scale(1.03)'; e.currentTarget.style.boxShadow = `0 8px 20px rgba(${S.Prgb},.15)` }}
                onMouseLeave={e => { e.currentTarget.style.borderColor = 'var(--md-outline)'; e.currentTarget.style.background = S.SV; e.currentTarget.style.transform = ''; e.currentTarget.style.boxShadow = '' }}>
                <span className="material-symbols-outlined" style={{ fontSize: 18, color: S.P }}>{t.icon || 'open_in_new'}</span>
                {t.label}
                <span className="material-symbols-outlined" style={{ fontSize: 14, color: S.OnSD, opacity: .6 }}>open_in_new</span>
              </a>
            ))}
          </div>
        </div>
      </Section>

      {/* ═══════════════════════════════════════════════
          UPDATES & KML (side by side)
      ═══════════════════════════════════════════════ */}
      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(400px, 1fr))', gap: 20 }}>
      <Section id="updates" icon="campaign" title="CC Important Updates" badge="Live Feed">
        <div className="m-upd">
          <div style={{ display: 'flex', alignItems: 'center', gap: 14, marginBottom: 24, flexWrap: 'wrap' }}>
            <div style={{
              width: 48, height: 48, borderRadius: 14,
              background: 'var(--md-primary)',
              color: '#fff', display: 'flex', alignItems: 'center', justifyContent: 'center',
              boxShadow: '0 6px 20px rgba(var(--md-primary-rgb),.3)',
            }}>
              <span className="material-symbols-outlined" style={{ fontSize: 26 }}>campaign</span>
            </div>
            <div style={{ flex: 1 }}>
              <h2 style={{ fontSize: 22, fontWeight: 900, color: S.P, margin: 0, letterSpacing: -.3 }}>CC IMPORTANT UPDATES</h2>
              <p style={{ fontSize: 12, opacity: .8, margin: '2px 0 0', fontWeight: 600, color: S.OnS }}>Live Feed & Essential Processing Sheets</p>
            </div>
            <div style={{ display: 'inline-flex', alignItems: 'center', gap: 5, padding: '4px 12px', borderRadius: 20, background: 'linear-gradient(135deg,var(--md-primary),#FF8F00)', color: '#fff', fontSize: 9, fontWeight: 800, letterSpacing: .6 }}>
              <span style={{ width: 5, height: 5, borderRadius: '50%', background: '#4CAF50', animation: 'mp 1.5s ease-in-out infinite', display: 'inline-block' }} />
              LIVE
            </div>
          </div>

          <div className="card" style={{ background: S.S, padding: '18px', border: '1px solid rgba(var(--md-primary-rgb),.12)', borderRadius: 18, marginBottom: 20, boxShadow: '0 4px 16px rgba(var(--md-primary-rgb),.04)' }}>
            <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 12, flexWrap: 'wrap', gap: 8 }}>
              <h3 style={{ fontSize: 15, fontWeight: 800, color: S.OnS, display: 'flex', alignItems: 'center', gap: 8, margin: 0 }}>
                <span className="material-symbols-outlined" style={{ color: S.P, fontSize: 20 }}>slideshow</span>
                Latest Update Feed
              </h3>
              <div style={{ display: 'flex', gap: 6 }}>
                <a href="https://docs.google.com/presentation/d/1wAToMjia1zZkeqPa6_fhoeL2Pl4O62WEcqdNzXS6nQA/edit"
                  target="_blank" rel="noopener noreferrer" className="btn"
                  style={{ fontSize: 10, padding: '5px 10px', borderRadius: 10, background: S.SV, color: S.OnS, border: '1px solid var(--md-outline)' }}>
                  <span className="material-symbols-outlined" style={{ fontSize: 14 }}>open_in_new</span>
                  Open
                </a>
              </div>
            </div>
            <div style={{ width: '100%', height: 340, position: 'relative', borderRadius: 12, overflow: 'hidden', border: '1px solid var(--md-outline)' }}>
              <iframe src="https://docs.google.com/presentation/d/1wAToMjia1zZkeqPa6_fhoeL2Pl4O62WEcqdNzXS6nQA/embed?start=true&loop=true&delayms=5000&rm=minimal"
                style={{ width: '100%', height: '100%', border: 'none' }} title="CC Update Feed" allowFullScreen />
              <button onClick={() => openPopup(feedEmbedUrl, 'CC Important Updates')}
                style={{
                  position: 'absolute', bottom: 8, right: 8, cursor: 'pointer', zIndex: 2,
                  background: 'rgba(0,0,0,.6)', color: '#fff', border: 'none',
                  fontSize: 9, fontWeight: 700, padding: '4px 10px', borderRadius: 6,
                  display: 'flex', alignItems: 'center', gap: 4,
                  transition: 'background .2s',
                }}
                onMouseEnter={e => e.currentTarget.style.background = 'rgba(0,0,0,.85)'}
                onMouseLeave={e => e.currentTarget.style.background = 'rgba(0,0,0,.6)'}>
                <span className="material-symbols-outlined" style={{ fontSize: 12 }}>zoom_out_map</span>
                Click to expand
              </button>
            </div>
            <p style={{ fontSize: 11, color: S.OnSV, margin: '12px 0 0', lineHeight: 1.6, display: 'flex', alignItems: 'center', gap: 6 }}>
              <span className="material-symbols-outlined" style={{ fontSize: 14, color: S.P }}>schedule</span>
              Stay updated with the latest process changes, weekly highlights, and urgent CC announcements.
            </p>
          </div>

          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(260px, 1fr))', gap: 12 }}>
            {updateResources.map(res => (
              <a key={res.label} href={res.url} target="_blank" rel="noopener noreferrer" style={{ textDecoration: 'none' }}>
                <div className="card" style={{
                  background: S.S, padding: '16px', display: 'flex', alignItems: 'center', gap: 12,
                  border: '1px solid rgba(var(--md-primary-rgb),.06)', borderRadius: 14,
                  transition: 'all .35s cubic-bezier(.34,1.56,.64,1)',
                }}
                  onMouseEnter={e => { e.currentTarget.style.borderColor = 'var(--md-primary)'; e.currentTarget.style.transform = 'translateY(-2px) scale(1.01)'; e.currentTarget.style.boxShadow = '0 10px 28px rgba(var(--md-primary-rgb),.08)' }}
                  onMouseLeave={e => { e.currentTarget.style.borderColor = 'rgba(var(--md-primary-rgb),.06)'; e.currentTarget.style.transform = ''; e.currentTarget.style.boxShadow = '' }}>
                  <div style={{ width: 42, height: 42, borderRadius: 10, background: `${res.color}14`, display: 'flex', alignItems: 'center', justifyContent: 'center', flexShrink: 0 }}>
                    <span className="material-symbols-outlined" style={{ color: res.color, fontSize: 22 }}>{res.icon}</span>
                  </div>
                  <div style={{ flex: 1 }}>
                    <h4 style={{ fontSize: 13, fontWeight: 800, color: S.OnS, margin: 0 }}>{res.label}</h4>
                    <p style={{ fontSize: 10, color: S.OnSV, margin: '3px 0 0', lineHeight: 1.5 }}>{res.desc}</p>
                  </div>
                  <span className="material-symbols-outlined" style={{ color: S.OnSD, fontSize: 16 }}>chevron_right</span>
                </div>
              </a>
            ))}
            <div style={{
              padding: '14px', background: 'rgba(var(--md-primary-rgb),.03)',
              borderRadius: 14, border: '1px dashed rgba(var(--md-primary-rgb),.2)',
              display: 'flex', alignItems: 'center', gap: 10,
            }}>
              <span className="material-symbols-outlined" style={{ fontSize: 20, color: S.P, flexShrink: 0 }}>lightbulb</span>
              <div style={{ fontSize: 11, color: S.P, fontWeight: 700, lineHeight: 1.5 }}>PRO TIP: Use Master Sheet for Zomato/Swiggy Tagging!</div>
            </div>
          </div>
        </div>
      </Section>

      {/* ═══════════════════════════════════════════════
          AUDIT UI
      ═══════════════════════════════════════════════ */}
      <Section id="audit" icon="analytics" title="Audit UI for Box8" badge="3 dashboards">
        <div style={{
          background: 'linear-gradient(135deg,rgba(var(--md-primary-rgb),.05),rgba(var(--md-primary-rgb),.01))',
          borderRadius: 22, padding: 28, border: '1px solid rgba(var(--md-primary-rgb),.12)',
          position: 'relative', overflow: 'hidden',
        }}>
          <p style={{ fontSize: 12, color: S.OnS, opacity: .75, marginBottom: 20, lineHeight: 1.5, maxWidth: 500 }}>
            High-priority operational dashboards for order auditing, manpower status, and delivery logistics.
          </p>
          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(280px, 1fr))', gap: 16 }}>
            {auditLinks.map((a) => (
              <div key={a.label} className="m-aud">
                <div style={{ display: 'flex', gap: 12, alignItems: 'center' }}>
                  <div style={{
                    width: 46, height: 46, borderRadius: 12,
                    background: 'linear-gradient(135deg,var(--md-primary),#FF8F00)',
                    display: 'flex', alignItems: 'center', justifyContent: 'center',
                    boxShadow: '0 4px 14px rgba(var(--md-primary-rgb),.18)',
                  }}>
                    <span className="material-symbols-outlined" style={{ color: '#fff', fontSize: 24 }}>{a.icon}</span>
                  </div>
                  <div>
                    <h4 style={{ fontSize: 14, fontWeight: 800, color: S.OnS }}>{a.label}</h4>
                    <div style={{ fontSize: 9, color: S.P, fontWeight: 700, textTransform: 'uppercase', letterSpacing: .6 }}>auditui.box8.co.in</div>
                  </div>
                </div>
                <p style={{ fontSize: 12, color: S.OnS, opacity: .85, lineHeight: 1.6, flex: 1 }}>{a.desc}</p>
                <div style={{ display: 'flex', marginTop: 2 }}>
                  <a href={a.url} target="_blank" rel="noopener noreferrer" className="btn"
                    style={{
                      flex: 1, padding: '8px 12px', fontSize: 12,
                      background: 'var(--md-primary)', color: '#fff',
                      borderRadius: 11, fontWeight: 800,
                      boxShadow: '0 4px 10px rgba(var(--md-primary-rgb),.2)',
                      justifyContent: 'center',
                    }}>
                    <span className="material-symbols-outlined" style={{ fontSize: 16 }}>open_in_new</span>
                    Open Dashboard
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>
      </Section>

      {/* ═══════════════════════════════════════════════
          KML MAP
      ═══════════════════════════════════════════════ */}
      <Section id="kml" icon="map" title="Outlet KML Map" badge="Live">
        <div className="m-kml">
          <div style={{
            padding: '12px 20px', background: S.SV,
            borderBottom: '1px solid var(--md-outline)',
            display: 'flex', justifyContent: 'space-between',
            alignItems: 'center', flexWrap: 'wrap', gap: 8,
          }}>
            <div style={{ display: 'flex', alignItems: 'center', gap: 10 }}>
              <div style={{ width: 34, height: 34, borderRadius: 8, background: 'rgba(var(--md-primary-rgb),.08)', display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
                <span className="material-symbols-outlined" style={{ color: S.P, fontSize: 18 }}>near_me</span>
              </div>
              <div>
                <div style={{ fontSize: 13, fontWeight: 800 }}>EatClub Outlet Network</div>
                <div style={{ fontSize: 10, color: S.OnS, opacity: .7 }}>Live KML Boundaries & Locations</div>
              </div>
            </div>
            <div style={{ display: 'flex', gap: 6 }}>
              <a href={kmlEditUrl} target="_blank" rel="noopener noreferrer" className="btn btn-primary"
                style={{ padding: '4px 8px', fontSize: 9, borderRadius: 9 }}>
                <span className="material-symbols-outlined" style={{ fontSize: 14 }}>open_in_new</span>
                External
              </a>
            </div>
          </div>
          <div style={{ width: '100%', height: 420, position: 'relative' }}>
            <iframe src={kmlEmbedUrl}
              style={{ width: '100%', height: '100%', border: 'none' }} title="Outlet KML Map" />
            <button onClick={() => openPopup(kmlEmbedUrl, 'EatClub Outlet Network')}
              style={{
                position: 'absolute', bottom: 8, right: 8, cursor: 'pointer', zIndex: 2,
                background: 'rgba(0,0,0,.6)', color: '#fff', border: 'none',
                fontSize: 9, fontWeight: 700, padding: '4px 10px', borderRadius: 6,
                display: 'flex', alignItems: 'center', gap: 4,
                transition: 'background .2s',
              }}
              onMouseEnter={e => e.currentTarget.style.background = 'rgba(0,0,0,.85)'}
              onMouseLeave={e => e.currentTarget.style.background = 'rgba(0,0,0,.6)'}>
              <span className="material-symbols-outlined" style={{ fontSize: 12 }}>zoom_out_map</span>
              Click to expand
            </button>
          </div>
        </div>
      </Section>
      </div>

      {/* ═══════════════════════════════════════════════
          MODALS
      ═══════════════════════════════════════════════ */}

      {/* VIDEO MODAL */}
      {activeVideo && (
        <div className="contact-modal-overlay" onClick={() => setActiveVideo(null)}>
          <div className="contact-card" onClick={e => e.stopPropagation()} style={{
            maxWidth: 840, background: S.S, borderRadius: 20,
            overflow: 'hidden', display: 'flex', flexDirection: 'column',
            boxShadow: '0 24px 64px rgba(0,0,0,.55)',
          }}>
            <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', padding: '12px 20px', borderBottom: '1px solid var(--md-outline)' }}>
              <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
                <span className="material-symbols-outlined" style={{ color: S.P, fontSize: 20 }}>play_circle</span>
                <h3 style={{ margin: 0, fontSize: 15, fontWeight: 700 }}>{activeVideo.title}</h3>
              </div>
              <button onClick={() => setActiveVideo(null)} style={{ background: S.SV, border: 'none', cursor: 'pointer', color: S.OnS, width: 28, height: 28, borderRadius: '50%', display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
                <span className="material-symbols-outlined" style={{ fontSize: 16 }}>close</span>
              </button>
            </div>
            <div style={{ position: 'relative', width: '100%', paddingTop: '56.25%', background: '#000' }}>
              <iframe src={activeVideo.url.replace('/view', '/preview')} style={{ position: 'absolute', top: 0, left: 0, width: '100%', height: '100%', border: 'none' }} allow="autoplay; fullscreen" title={activeVideo.title} />
            </div>
            <div style={{ padding: '18px', textAlign: 'center' }}>
              <div style={{ marginBottom: 12, fontSize: 12, color: S.OnSV, lineHeight: 1.6 }}>Watch the entire training video, then verify your knowledge with a quiz mapping directly to its contents.</div>
              <div style={{ display: 'flex', justifyContent: 'center', gap: 8, flexWrap: 'wrap' }}>
                <button className="btn" onClick={() => setActiveVideo(null)} style={{ background: S.SV, color: S.OnS, border: '1px solid var(--md-outline)', fontSize: 12 }}>Close</button>
                <button className="btn btn-primary" onClick={() => { setActiveVideo(null); navigate('quiz'); }} style={{ padding: '8px 20px', display: 'inline-flex', alignItems: 'center', gap: 6, fontSize: 12 }}>
                  <span className="material-symbols-outlined" style={{ fontSize: 15 }}>quiz</span>
                  Take {activeVideo.title.match(/Part-\d/)?.[0] || 'Training'} Quiz
                </button>
              </div>
            </div>
          </div>
        </div>
      )}



      {copiedNumber && (
        <div style={{
          position: 'fixed', bottom: 24, left: '50%', transform: 'translateX(-50%)',
          zIndex: 200000, display: 'flex', alignItems: 'center', gap: 8,
          padding: '10px 20px', borderRadius: 12,
          background: S.SV, color: S.OnS,
          border: `1px solid ${S.Out}`,
          fontSize: 13, fontWeight: 700,
          boxShadow: '0 8px 24px rgba(0,0,0,.4)',
          animation: 'mfade .2s ease',
        }}>
          <span className="material-symbols-outlined" style={{ fontSize: 16, color: S.P }}>check</span>
          Copied: {copiedNumber}
        </div>
      )}
    </div>
  );
}
