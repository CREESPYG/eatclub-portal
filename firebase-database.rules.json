{
  "rules": {
    "notes": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },
    "users": {
      ".read": "auth.uid !== null",
      "$uid": {
        ".write": "auth.uid !== null && ($uid === auth.uid || (!data.child('email').exists() || (data.child('email').val() !== 'pooja8.box8@gmail.com' && data.child('email').val() !== 'aarif.box8@gmail.com')))",
        "role": {
          ".write": "auth.uid !== null && ($uid === auth.uid || (!root.child('users').child($uid).child('email').exists() || (root.child('users').child($uid).child('email').val() !== 'pooja8.box8@gmail.com' && root.child('users').child($uid).child('email').val() !== 'aarif.box8@gmail.com')))",
          ".validate": "($uid !== auth.uid) || (newData.val() !== 'Admin' && newData.val() !== 'Super Admin')"
        }
      }
    },
    "leaderboard": {
      ".read": "auth.uid !== null",
      "$uid": {
        ".write": "$uid === auth.uid || (newData.exists() && root.child('users').child($uid).child('email').val() !== 'pooja8.box8@gmail.com' && root.child('users').child($uid).child('email').val() !== 'aarif.box8@gmail.com')"
      }
    },
    "chats": {
      ".read": "auth.uid !== null",
      ".write": "auth.uid !== null",
      "$messageId": {
        ".validate": "newData.hasChildren(['id', 'user', 'text', 'timestamp'])"
      }
    },
    "conversations": {
      "$conversationId": {
        ".read": "auth.uid !== null && data.child('metadata/participants').hasChild(auth.uid)",
        ".write": "auth.uid !== null && (!data.exists() || data.child('metadata/participants').hasChild(auth.uid))",
        "metadata": {
          ".read": "auth.uid !== null && root.child('conversations').child($conversationId).child('metadata/participants').hasChild(auth.uid)",
          ".write": "auth.uid !== null"
        },
        "messages": {
          "$messageId": {
            ".read": "auth.uid !== null && root.child('conversations').child($conversationId).child('metadata/participants').hasChild(auth.uid)",
            ".write": "auth.uid !== null && root.child('conversations').child($conversationId).child('metadata/participants').hasChild(auth.uid)"
          }
        }
      }
    },
    "presence": {
      ".read": "auth.uid !== null",
      "$uid": {
        ".write": "$uid === auth.uid"
      }
    },
    "typing": {
      "$conversationId": {
        "$userId": {
          ".read": "auth.uid !== null",
          ".write": "$userId === auth.uid"
        }
      }
    },
    "notices": {
      ".read": "auth.uid !== null",
      "$noticeId": {
        ".write": "auth.uid !== null && root.child('users').child(auth.uid).child('role').val() !== ''",
        ".validate": "newData.hasChildren(['title', 'createdAt'])",
        "readBy": {
          "$uid": {
            ".write": "$uid === auth.uid"
          }
        }
      }
    },
    "noticeAudit": {
      "$noticeId": {
        ".read": "auth.uid !== null && root.child('users').child(auth.uid).child('role').val() !== ''",
        ".write": "auth.uid !== null && root.child('users').child(auth.uid).child('role').val() !== ''"
      }
    },
    "noticeBoardConfig": {
      ".read": "auth.uid !== null",
      ".write": "auth.uid !== null && (root.child('users').child(auth.uid).child('email').val() === 'pooja8.box8@gmail.com' || root.child('users').child(auth.uid).child('email').val() === 'aarif.box8@gmail.com')"
    },
    "trainingVideos": {
      ".read": "auth.uid !== null",
      ".write": "auth.uid !== null && (root.child('users').child(auth.uid).child('isAdmin').val() === true || root.child('users').child(auth.uid).child('email').val() === 'pooja8.box8@gmail.com' || root.child('users').child(auth.uid).child('email').val() === 'aarif.box8@gmail.com' || root.child('users').child(auth.uid).child('role').val() === 'Admin')",
      "$videoId": {
        ".validate": "newData.hasChildren(['title', 'url']) && newData.child('title').val().length > 0 && newData.child('url').val().length > 0"
      }
    }
  }
}
